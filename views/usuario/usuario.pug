extends ../layout.pug

block metadata
    title Usuario: #{Usuario ? Usuario.username : 'No encontrado'}

block content
    div
        if Usuario
            h1 Bienvenido #{Usuario.firstName || Usuario.username}
            p Cuenta creada desde #{new Date(Usuario.createdAt).toLocaleDateString('es-AR')}
            if Usuario.birthDate
                p Cumpleaños: #{Usuario.birthDate}
            a(href="#") seguidores
            a(href="#") siguiendo
        else 
            h1 No se encontro el usuario
    div 
        
        a(href="#") editar

        a(href="#") denunciar