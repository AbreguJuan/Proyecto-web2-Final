extends ../layout.pug

block metadata
    title Usuario: #{Usuario ? Usuario.username : 'No encontrado'}

block content
    div
        if Usuario
            div 
                h1 Bienvenido #{Usuario.firstName || Usuario.username}
            div
                p Cuenta creada desde el #{new Date(Usuario.createdAt).toLocaleDateString('es-AR')}
            div            
                if Usuario.birthDate
                    p Cumpleaños: #{Usuario.birthDate}
            div
                a(href="#") seguidores
            div
                a(href="#") siguiendo
        else 
            div
                h1 No se encontro el usuario
    
    div 
        a(href="#") editar
    div
        a(href="#") denunciar

    div 
        if Usuario.Publicaciones
            each post in Usuario.Publicaciones 
                div
                    h2 #{post.titulo} 
                div
                    h3 #{post.contenido}
                div
                    if post.Imagens
                        each imagen in post.Imagens
                            img(src=`${imagen.metadata},${imagen.contenido.toString('base64')}` style="width:300px")
                div 
                    if post.Etiqueta
                        each etiqueta in post.Etiqueta
                            p #{etiqueta.etiqueta}
                div
                    p Creado #{new Date(post.createdAt).toLocaleDateString('es-AR')}
                div
                    a Creado por: #{post.Autor.firstName || post.Autor.username}
                div
                    a Me gusta Publicacion
                div
                    a Comentarios Publicacion